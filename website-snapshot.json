    uid=3_17 heading "Laravel performance profiling for LLM coding agents." level="1"
    uid=3_18 StaticText "Capture queries, detect performance issues or N+1 patterns, and run"
    uid=3_19 StaticText " "
    uid=3_20 StaticText "EXPLAIN ANALYZE"
    uid=3_21 StaticText " "
    uid=3_22 StaticText "— all via Artisan commands that output structured JSON to stdout. No browser, no GUI."
    uid=3_23 link "View on GitHub" url="https://github.com/mateffy/laraperf"
      uid=3_24 StaticText "View on GitHub"
