    uid=3_147 heading "perf:watch" level="3"
    uid=3_148 StaticText "Start a capture session. Returns immediately by default (detached). Workers run in the background and append queries to a JSON file."
    uid=3_149 StaticText "--sync"
    uid=3_150 StaticText "Run in foreground; Ctrl+C or timeout ends it"
    uid=3_151 StaticText "--seconds=N"
    uid=3_152 StaticText "Window duration. Default: 300"
    uid=3_153 StaticText "--forever"
    uid=3_154 StaticText "Keep alive indefinitely (detached only)"
    uid=3_155 StaticText "--tag=label"
    uid=3_156 StaticText "Label stored in session metadata"
    uid=3_157 StaticText "bash"
    uid=3_158 StaticText "$ php artisan perf:watch --seconds=120
✓ session=session-20260416-143201-xK9mQp pid=47821 duration=120s
  Use `perf:stop` to stop early, or wait for the timeout.
  Then run: php artisan perf:query --session=session-20260416-143201-xK9mQp"
